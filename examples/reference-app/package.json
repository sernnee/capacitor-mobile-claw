{
  "name": "mobile-claw-reference-app",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "node -e \"const{execSync}=require('child_process'),{existsSync}=require('fs');if(!existsSync('../../dist')){console.log('Building capacitor-mobile-claw...');execSync('npm install --ignore-scripts',{cwd:'../../',stdio:'inherit'});execSync('./node_modules/.bin/tsc',{cwd:'../../',stdio:'inherit'})}\"",
    "postinstall": "node scripts/patch-sqlite-ios.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:build": "vite build && npm run cap:sync",
    "setup:android": "node scripts/setup-android.mjs",
    "setup:ios": "node scripts/setup-ios.mjs",
    "build:android": "npm run cap:build && cd android && ./gradlew assembleDebug",
    "build:ios": "npm run cap:build && cd ios/App && xcodebuild -project App.xcodeproj -scheme App -sdk iphonesimulator -configuration Debug build CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO ARCHS=arm64 ONLY_ACTIVE_ARCH=YES -quiet",
    "test:full": "node scripts/test-full.mjs",
    "test:android": "node test-sentinel-e2e.mjs",
    "test:ios": "node test-sentinel-e2e-ios.mjs"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "capacitor-lancedb": "^0.2.0",
    "capacitor-mobile-claw": "file:../../",
    "capacitor-mobilecron": "^0.2.19",
    "marked": "^15.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.0.0",
    "vite": "^6.2.0",
    "ws": "^8.18.0"
  }
}
