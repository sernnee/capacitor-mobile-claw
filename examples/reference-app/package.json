{
  "name": "mobile-claw-reference-app",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:worker": "rm -rf public/nodejs-project && mkdir -p public && cp -R ../../nodejs-assets/nodejs-project public/nodejs-project && rm -rf public/nodejs-project/node_modules && cd public/nodejs-project && npm install --production",
    "preinstall": "node -e \"const{execSync}=require('child_process'),{existsSync}=require('fs');if(!existsSync('../../dist')){console.log('Building capacitor-mobile-claw...');execSync('npm install --ignore-scripts',{cwd:'../../',stdio:'inherit'});execSync('./node_modules/.bin/tsc',{cwd:'../../',stdio:'inherit'})}\"",
    "postinstall": "npm run setup:worker",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync && cp -R node_modules/@choreruiz/capacitor-node-js/ios/assets/builtin_modules ios/App/App/public/builtin_modules 2>/dev/null; true",
    "cap:build": "npm run setup:worker && vite build && npm run cap:sync"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@choreruiz/capacitor-node-js": "^1.0.0",
    "capacitor-lancedb": "^0.1.4",
    "capacitor-mobile-claw": "file:../../",
    "capacitor-mobilecron": "^0.2.19",
    "marked": "^15.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.0.0",
    "vite": "^6.2.0"
  }
}
