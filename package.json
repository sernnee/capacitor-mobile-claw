{
  "name": "capacitor-mobile-claw",
  "version": "1.6.2",
  "description": "On-device AI agent engine for Capacitor apps — embedded Node.js worker with LLM, file tools, code execution, git, and extensible MCP server",
  "main": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "type": "module",
  "scripts": {
    "worker:install": "cd nodejs-assets/nodejs-project && npm install --production",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepack": "npm run build"
  },
  "files": [
    "dist/esm/",
    "nodejs-assets/",
    "!nodejs-assets/nodejs-project/node_modules/"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@capacitor-community/sqlite": ">=6.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/device": "^8.0.0",
    "@choreruiz/capacitor-node-js": ">=1.0.0",
    "@mariozechner/pi-agent-core": ">=0.55.0",
    "@mariozechner/pi-ai": ">=0.55.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "@sinclair/typebox": ">=0.34.0",
    "capacitor-mobilecron": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "capacitor-mobilecron": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/device": "^8.0.1",
    "@choreruiz/capacitor-node-js": "^1.0.0",
    "@mariozechner/pi-agent-core": "^0.55.1",
    "@mariozechner/pi-ai": "^0.55.1",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sinclair/typebox": "^0.34.41",
    "@stomp/stompjs": "^7.0.0",
    "isomorphic-git": "^1.37.2",
    "lefthook": "^1.6.0",
    "pyodide": "^0.27.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "capacitor",
    "capacitor-plugin",
    "on-device",
    "ai",
    "agent",
    "llm",
    "anthropic",
    "claude",
    "node.js",
    "file-tools",
    "mcp",
    "model-context-protocol",
    "mobile",
    "android",
    "ios"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rogelioRuiz/capacitor-mobile-claw.git"
  },
  "homepage": "https://github.com/rogelioRuiz/capacitor-mobile-claw#readme",
  "bugs": {
    "url": "https://github.com/rogelioRuiz/capacitor-mobile-claw/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
