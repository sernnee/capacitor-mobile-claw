{
  "name": "capacitor-mobile-claw",
  "version": "1.8.0",
  "description": "On-device AI agent engine for Capacitor apps — native WebView LLM agent with file tools, code execution, git, and extensible MCP server",
  "main": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "type": "module",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/esm/vite-plugin.d.ts",
      "import": "./dist/esm/vite-plugin.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"try{require('@biomejs/biome/bin/biome')}catch{const{platform,arch}=process;const p='@biomejs/cli-'+platform+'-'+arch;console.log('Installing '+p+'...');require('child_process').execSync('npm install '+p,{stdio:'inherit'})}\" 2>/dev/null || true",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepack": "npm run build"
  },
  "files": [
    "dist/esm/",
    "android/src/main/",
    "android/build.gradle",
    "ios/Plugin/",
    "CapacitorMobileClaw.podspec"
  ],
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.55.1",
    "@mariozechner/pi-ai": "^0.55.1",
    "@sinclair/typebox": "^0.34.41",
    "isomorphic-git": "^1.37.2"
  },
  "peerDependencies": {
    "@capacitor-community/sqlite": ">=6.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/device": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "capacitor-mobilecron": ">=0.1.0",
    "capacitor-wasm-agent-tools": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "capacitor-mobilecron": {
      "optional": true
    },
    "capacitor-wasm-agent-tools": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@stomp/stompjs": "^7.0.0",
    "capacitor-wasm-agent-tools": "^0.1.0",
    "isomorphic-git": "^1.37.2",
    "lefthook": "^1.6.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "capacitor",
    "capacitor-plugin",
    "on-device",
    "ai",
    "agent",
    "llm",
    "anthropic",
    "claude",
    "file-tools",
    "mcp",
    "model-context-protocol",
    "mobile",
    "android",
    "ios"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rogelioRuiz/capacitor-mobile-claw.git"
  },
  "homepage": "https://github.com/rogelioRuiz/capacitor-mobile-claw#readme",
  "bugs": {
    "url": "https://github.com/rogelioRuiz/capacitor-mobile-claw/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  }
}
